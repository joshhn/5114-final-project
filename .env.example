# Copy this file to .env and fill in real values.
# cp .env.example .env

# Project root used by Airflow DAG and helper scripts.
PROJECT_DIR=/absolute/path/to/5114-final-project

# Local Airflow isolation (recommended).
AIRFLOW_HOME=${PROJECT_DIR}/.airflow
AIRFLOW__CORE__DAGS_FOLDER=${PROJECT_DIR}/airflow
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Airflow metadata DB backend (recommended for local concurrency).
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://localhost/airflow_meta

# Optional local concurrency tuning.
AIRFLOW__CORE__PARALLELISM=8
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=4
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=1
AIRFLOW__SCHEDULER__PARSING_PROCESSES=2

# This replaces creating the Snowflake connection in Airflow UI.
# Keep the value quoted because `source .env` is used and the URI contains `&`.
# URI format: snowflake://USER:PASSWORD@/SCHEMA?account=ACCOUNT&database=DB&warehouse=WH
AIRFLOW_CONN_SNOWFLAKE_DEFAULT='snowflake://USER:PASSWORD@/FINAL_PROJECT_RAW?account=ACCOUNT&database=DB&warehouse=WH'

# Spark dependency bundle used by DAG and helper scripts.
SPARK_PACKAGES=org.apache.spark:spark-hadoop-cloud_2.12:3.5.0,org.apache.spark:spark-protobuf_2.12:3.5.0,org.apache.hadoop:hadoop-aws:3.3.4,com.amazonaws:aws-java-sdk-bundle:1.12.262,net.snowflake:spark-snowflake_2.12:3.0.0,net.snowflake:snowflake-jdbc:3.13.30

# AWS credentials for Spark S3 reads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-2

# S3 locations
S3_RT_PATH_PREFIX=s3a://5114-transit-project-data/boston/rt/
S3_STATIC_PATH_PREFIX=s3a://5114-transit-project-data/boston/gtfs_static/

# GTFS realtime protobuf descriptor path
REALTIME_SPEC_PATH=${PROJECT_DIR}/spark/gtfs-realtime.desc

# Snowflake connection values used by Spark loaders
SNOWFLAKE_URL=
SNOWFLAKE_USER=
SNOWFLAKE_DATABASE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_RAW_SCHEMA=FINAL_PROJECT_RAW
SNOWFLAKE_STATIC_SCHEMA=FINAL_PROJECT_STATIC
# Optional. Leave empty to use the user's default role.
SNOWFLAKE_ROLE=

# Snowflake key-pair auth files used by Spark loaders
SNOWFLAKE_PRIVATE_KEY_PATH=${PROJECT_DIR}/spark/snowflake_auth/rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSWORD=

# Runtime overrides used by Spark scripts for manual runs.
SERVICE_DATE=
RT_FEED_TYPE=vehicle_positions
